{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "System": {
    "DatasetAccessMode": "Open",
    "EnableTenancy": true
  },
  "Storage": {
    "Provider": "FileSystem",
    "FileSystem": {
      "BasePath": "/var/open"
    },
    "S3": {
      "ServiceUrl": "http://localhost:9000",
      "BucketName": "test",
      "AccessKey": "test",
      "SecretKey": "testtest",
      "ForcePathStyle": true,
      "MultiPartUploadThreshold": 104857600,
      "MultiPartUploadChunkSize": 10485760,
      "RequestChecksumCalculationEnabled": true,
      "ResponseChecksumCalculationEnabled": true
    },
    "NextCloud": {
      "BaseUrl": "http://localhost:8090",
      "BasePath": "test",
      "TempFilePath": "tmp",
      "User": "test",
      "Password": "test",
      "ChunkedUploadThreshold": 104857600,
      "ChunkedUploadChunkSize": 10485760
    }
  },
  "Security": {
    "AllowReadDraftFiles": true,
    "JwksUri": "http://localhost:8080/jwks",
    "CorsAllowedOrigins": [
      "http://localhost:8080"
    ],
    "PublicKeyPem": "-----BEGIN PUBLIC KEY-----\nMFkwEwYHKoZIzj0CAQYIKoZIzj0DAQcDQgAEkrJV3reTAGXAXWR5m3/h3GWUltAz\nFnn3S8QKC4/8dvorNzfUHFe16HMhbWNI6FijgsK21AJhCU9JmxdAFtwfew==\n-----END PUBLIC KEY-----"
  },
  "PublicUrl": "http://localhost:8080"
}